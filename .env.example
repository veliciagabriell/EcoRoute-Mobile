# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ecoroute

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_EXP=15m
JWT_REFRESH_EXP=7d

# API Key for IoT HTTP endpoint
IOT_API_KEY=supersecretapikey

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883

# Firebase
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# App
PORT=3000
NODE_ENV=development

# Route optimization defaults (ITB Ganesha -> Tamansari)
ROUTE_START_LAT=-6.89148
ROUTE_START_LNG=107.61070
ROUTE_END_LAT=-6.90035
ROUTE_END_LNG=107.60657

# Free routing engine (OSRM public)
ROUTE_ENGINE_URL=https://router.project-osrm.org
